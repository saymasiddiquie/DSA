#include<iostream>
using namespace std;
 
int main(){
    string n;
    cin>>n;
    int dotIndex=0;
    for(int i=0;i<n.length();i++){
        if(n[i]=='.'){
            dotIndex=i;
            break;
        }
    }
    if(n[dotIndex-1]=='9'){
        cout << "GOTO Vasilisa.";
        return 0;
    }
    if(n[dotIndex+1]>='5'){
        n[dotIndex-1]++;
            
    }
    for(int i=0;i<dotIndex;i++){
        cout<<n[i];
    }
        
    
}

#include <bits/stdc++.h>
using namespace std;

int main() {
    string n, n2;
    cin >> n >> n2;

    if(n.length() != n2.length()){
        cout << "not an anagram";
        return 0;
    }

    for(int i = 0; i < n.length(); i++){
        bool found = false;

        for(int j = 0; j < n2.length(); j++){
            if(n[i] == n2[j]){
                found = true;
                n2[j] = '0';   
                break;
            }
        }

        if(found == false){
            cout << "not an anagram";
            return 0;
        }
    }

    cout << "anagram";   
}

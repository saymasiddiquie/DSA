#include <bits/stdc++.h>
using namespace std;

int main(){

    int n;
    cin >> n;

    int arr[n];

    for(int i = 0; i < n; i++){
        cin >> arr[i];
    }

    int j = 0;
    sort(arr,arr+n);
    for(int i=0;i<n;i++){
        if(arr[i]!=arr[j]){
            swap(arr[i],arr[j]);
            j++;
            
        }
    }
    for(int k=0;k<n;k++){
        cout<<arr[k];
    }

}

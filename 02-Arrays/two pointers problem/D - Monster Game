#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while(t--) {
        int n;
        cin >> n;

        vector<int> a(n), b(n);
        for(int i = 0; i < n; i++) cin >> a[i];
        for(int i = 0; i < n; i++) cin >> b[i];

        sort(a.begin(), a.end());

        // prefix sum of b
        vector<long long> prefix(n+1, 0);
        for(int i = 0; i < n; i++) {
            prefix[i+1] = prefix[i] + b[i];
        }

        long long ans = 0;

        for(int i = 0; i < n; i++) {
            int x = a[i];

            // usable swords
            int pos = lower_bound(a.begin(), a.end(), x) - a.begin();
            int usable = n - pos;

            // max k such that prefix[k] <= usable
            int k = upper_bound(prefix.begin(), prefix.end(), usable) - prefix.begin() - 1;

            ans = max(ans, 1LL * x * k);
        }

        cout << ans << "\n";
    }

    return 0;
}

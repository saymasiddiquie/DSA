#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;

    while(t--) {
        int n, k;
        cin >> n >> k;

        string s;
        cin >> s;

        int countW = 0;

        // First window
        for(int i = 0; i < k; i++) {
            if(s[i] == 'W') countW++;
        }

        int ans = countW;

        // Sliding window
        for(int i = k; i < n; i++) {
            // remove left
            if(s[i - k] == 'W') countW--;

            // add right
            if(s[i] == 'W') countW++;

            ans = min(ans, countW);
        }

        cout << ans << endl;
    }
}

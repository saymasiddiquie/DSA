#include <bits/stdc++.h>
using namespace std;

int main() {
    int n;
    cin>>n;
    int arr[n],result[n];
    for(int i=0;i<n;i++){
        cin>>arr[i];
    }
    int left=0;
    int right=n-1;
    for(int i=n-1;i>=0;i--){
        if(abs(arr[left])>abs(arr[right])){
            result[i]=arr[left]*arr[left];
            left++;
        }
        else{
            result[i]=arr[right]*arr[right];
            right--;
        }
        
    }
    for(int i=0;i<n;i++){
        cout<<result[i]<<" ";
    }
    
}

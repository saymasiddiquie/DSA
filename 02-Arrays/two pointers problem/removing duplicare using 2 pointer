#include <bits/stdc++.h>
using namespace std;

int main(){

    int n;
    cin >> n;

    int arr[n];

    for(int i = 0; i < n; i++){
        cin >> arr[i];
    }

    int left = 0;
    sort(arr,arr+n);

    for(int right = 1; right < n; right++){

        if(arr[left] != arr[right]){
            left++;
            arr[left] = arr[right];
        }

    }

    cout << "Array after removing duplicates:\n";

    for(int i = 0; i <= left; i++){
        cout << arr[i] << " ";
    }

}

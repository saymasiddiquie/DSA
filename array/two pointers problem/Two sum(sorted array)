#include <bits/stdc++.h>
using namespace std;

int main() {
    int n;
    cin>>n;
    int arr[n];
    for(int i=0;i<n;i++){
        cin>>arr[i];
    }
    int target=6;
    int left =0;
    int right=n-1;
    bool found=false;
    while(left<right){
        int sum=arr[left] + arr[right];
        if(sum==target){
            found=true;
            cout<<arr[left]<<" "<<arr[right];
            break;
        }
        else if(sum<target){
            left++;
        }
        else{
            right--;
        }
    }
    if(found == false){
        cout<<"no pair found";
    }
    
}

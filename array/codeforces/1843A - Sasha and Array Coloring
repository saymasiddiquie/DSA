#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;

    while(t--) {
        int n;
        cin >> n;

        vector<int> a(n);
        for(int i = 0; i < n; i++) {
            cin >> a[i];
        }

        sort(a.begin(), a.end());

        int i = 0, j = n - 1;
        int cost = 0;

        while(i < j) {
            cost += (a[j] - a[i]);
            i++;
            j--;
        }

        cout << cost << endl;
    }
}

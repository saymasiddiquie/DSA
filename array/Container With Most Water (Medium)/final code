#include <bits/stdc++.h>
using namespace std;

int main() {
	int n;
	cin>>n;
	int arr[n];
	for(int i=0;i<n;i++){
	    cin>>arr[i];
	}
	int left=0;
	int right=n-1;
	int maxArea=0;
	while(left<right){
	    int width=right-left;
    	int height=min(arr[left],arr[right]);
    	int area=height*width;
    	maxArea=max(maxArea,area);
    	if(arr[left]<arr[right]){
    	    left++;
    	}
    	else{
    	    right--;
    	}
	}
	cout<<maxArea;

}

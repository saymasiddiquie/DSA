#include <bits/stdc++.h>
using namespace std;

int main() {
	int n;
	cin>>n;
	int arr[n];
	for(int i=0;i<n;i++){
	    cin>>arr[i];
	}
	int left=0;
	int right=n-1;
	int width=right-left;
	int height=min(arr[left],arr[right]);
	float area=height*width;
	cout<<height<<endl;
	cout<<width<<endl;
	cout<<area;

}

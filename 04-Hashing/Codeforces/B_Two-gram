#include <bits/stdc++.h>
using namespace std;

int main() {
    int n;
    string s;
    
    cin >> n >> s;

    unordered_map<string, int> mp;

    for(int i = 0; i < n - 1; i++) {
        string two = "";
        two += s[i];
        two += s[i + 1];

        mp[two]++;
    }

    int maxi = 0;
    string ans = "";

    for(auto it : mp) {
        if(it.second > maxi) {
            maxi = it.second;
            ans = it.first;
        }
    }

    cout << ans;

    return 0;
}

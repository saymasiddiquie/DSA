#include <iostream>
using namespace std;

int main() {
    int n; cin >> n;
    int arr[n];
    for(int i=0; i<n; i++) cin >> arr[i];

    // Pre-compute: 
    // If numbers in arr are up to 12, we need size 13
    int hash[13] = {0}; 
    for(int i=0; i<n; i++) {
        hash[arr[i]]+=1;
    }
    int maxFreq = 0;
    int result = -1;

    // We loop through the HASH array (indices 0 to 12)
    for(int i=0; i<13; i++) { 
        if(hash[i] > maxFreq) {
            maxFreq = hash[i];
            result = i; // 'i' is the actual number from the input
        }
    }
    cout << result << endl; 
    cout<<maxFreq<<endl;
    return 0;
}

#include <iostream>
using namespace std;

int main() {
    int n; cin >> n;
    int arr[n];
    for(int i=0; i<n; i++) cin >> arr[i];

    // Pre-compute: 
    // If numbers in arr are up to 12, we need size 13
    int hash[13] = {0}; 
    for(int i=0; i<n; i++) {
        hash[arr[i]] += 1;
    }

    // Query: How many times does '3' appear?
    cout << hash[2] << endl; 
    return 0;
}

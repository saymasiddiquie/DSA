#include <bits/stdc++.h>
using namespace std;

int main(){
    string n;
    cin>>n;
    int lower=0;
    int upper=0;
    for(int i=0;i<n.length();i++){
        if(n[i]>='a' &&  n[i]<='z'){
            n[i]-=32;
            lower++;
        }
        else if(n[i]>='A' && n[i]<='Z'){
            n[i]+=32;
            upper++;
        }
    }
    cout<<n<<endl;
    cout<<lower<<endl;
    cout<<upper<<endl;
    
}

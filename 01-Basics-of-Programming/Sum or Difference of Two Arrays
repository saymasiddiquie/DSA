#include <bits/stdc++.h>
using namespace std;

int main() {
    int n1, n2;
    cin >> n1 >> n2;
    int a1[n1], a2[n2];
    
    for(int i=0; i<n1; i++) cin >> a1[i];
    for(int i=0; i<n2; i++) cin >> a2[i];
    int size=max(n1,n2);
    int sum[size];
    int i=n1-1;
    int j=n2-1;
    int k=size-1;
    int carry=0;
    while(k>=0){
        int digit=carry;
        if(i>=0){
            digit+=a1[i];
        }
        if(j>=0){
            digit+=a2[i];
        }
        carry =digit/10;
        digit=digit%10;
        
        sum[k]=digit;
        i--;j--;k--;
    }
    if(carry != 0) cout << carry << "\t"; // Final extra carry
    for(int val : sum){
        cout << val << "\t";
    } 
}

#include <iostream>
using namespace std;
struct Node {
    int data;
    Node* next;
};
void first(Node* head){
    while(head!=NULL){
        cout<<head->data<<" ";
        head=head->next;
    }
    cout<<endl;
}
int main(){
    Node* head=new Node{2,NULL};
    head->next=new Node{3,NULL};
    head->next->next=new Node{4,NULL};
    first(head);
}

#include <bits/stdc++.h>

using namespace std;

int main() {
    string s;
    cin >> s;
    int start=0;
    int end=s.length()-1;
    bool palindrome=false;
    while(start<end){
        if(s[start]==s[end]){
            palindrome=true;
            break;
        }
        start++;
        end--;
        
    }
    if(palindrome){
        cout<<"yes";
    }
    else{
        cout<<"no";
    }

}

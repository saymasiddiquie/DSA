#include <bits/stdc++.h>
using namespace std;

int main(){
    string n;
    cin>>n;
    for(int i=0;i<n.length();i++){
        if(n[i]=='0'){
            continue;
        }
        int count=1;
        for(int j=i+1;j<n.length();j++){
            if(n[i]==n[j]){
                count++;
                n[j]='0';
            }
        }
        cout<<n[i]<<" = "<<count<<endl;
    }
}

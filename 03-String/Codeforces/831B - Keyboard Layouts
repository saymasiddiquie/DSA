#include <iostream>
using namespace std;

int main() {

    string a, b, s;
    cin >> a >> b >> s;

    for(int i = 0; i < s.length(); i++) {

        if(s[i] >= '0' && s[i] <= '9') {
            cout << s[i];
        }

        else if(s[i] >= 'a' && s[i] <= 'z') {

            for(int j = 0; j < 26; j++) {
                if(s[i] == a[j]) {
                    cout << b[j];
                    break;
                }
            }

        }

        else if(s[i] >= 'A' && s[i] <= 'Z') {

            char ch = s[i] + 32;   

            for(int j = 0; j < 26; j++) {
                if(ch == a[j]) {
                    cout << char(b[j] - 32);  
                    break;
                }
            }

        }
    }

}

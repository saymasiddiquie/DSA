#include <iostream>
using namespace std;
 
int main(){
    string n;
    cin>>n;
    string p="heidi";
    int j=0;
    for(int i=0;i<n.length();i++){
        if(n[i]==p[j]){
            j++;
        }
        if(j==p[j]){
            break;
        }
    }
    if(j==p.length()){
        cout<<"YES";
    }
    else{
        cout<<"NO";
    }
}

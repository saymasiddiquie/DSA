#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;
    while (t--) {
        int n;
        cin >> n;
        string s;
        cin >> s;

        long long ans = 0;
        long long bCount = 0;
        long long last = 0;

        for (int i = n - 1; i >= 0; i--) {
            if (s[i] == 'B') {
                bCount++;
            } else {
                long long moves = min(bCount, last + 1);
                ans += moves;
                last = moves;
            }
        }

        cout << ans << '\n';
    }
}

#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;

    while(t--) {
        int n, k;
        cin >> n >> k;

        string s;
        cin >> s;

        int countB = 0;

        for(int i = 0; i < n; i++) {
            if(s[i] == 'B') countB++;
        }

        // Case 1: Already equal
        if(countB == k) {
            cout << 0 << endl;
            continue;
        }

        // Case 2: Need more B
        if(countB < k) {
            int need = k - countB;

            for(int i = 0; i < n; i++) {
                if(s[i] == 'A') {
                    need--;
                }
                if(need == 0) {
                    cout << 1 << endl;
                    cout << i+1 << " B" << endl;
                    break;
                }
            }
        }

        // Case 3: Need less B
        else {
            int extra = countB - k;

            for(int i = 0; i < n; i++) {
                if(s[i] == 'B') {
                    extra--;
                }
                if(extra == 0) {
                    cout << 1 << endl;
                    cout << i+1 << " A" << endl;
                    break;
                }
            }
        }
    }
}
